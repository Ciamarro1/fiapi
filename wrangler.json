{
  "name": "fiapi",
  "main": "src/index.js",
  "compatibility_date": "2024-04-03",
  "vars": {
    "AUTH_TOKEN": "default-secret-token",
    "MOCK_AI": "true",
    "RATE_LIMIT_MAX": "60",
    "RATE_LIMIT_WINDOW": "60"
  },
  "kv_namespaces": [
    {
      "binding": "RATE_LIMIT_KV",
      "id": "rate_limit_kv_id_placeholder",
      "preview_id": "rate_limit_kv_preview_id_placeholder"
    }
  ],
  "ai": {
    "binding": "AI"
  }
}
